if(WIN32)
    if(MSVC AND (CMAKE_GENERATOR MATCHES "^Visual Studio"))
        if((CMAKE_GENERATOR_PLATFORM STREQUAL "x64") OR (CMAKE_GENERATOR MATCHES "Win64"))
            set(ZENGINE_ARCH_NAME "x64")
            set(ZENGINE_VS_PLATFORM_NAME "x64")
        elseif((CMAKE_GENERATOR_PLATFORM STREQUAL "ARM64") OR (CMAKE_GENERATOR MATCHES "ARM64"))
            set(ZENGINE_ARCH_NAME "arm64")
            set(ZENGINE_VS_PLATFORM_NAME "ARM64")
        else()
            message(FATAL_ERROR "This CPU architecture is not supported")
        endif()
    endif()

    set(ZENGINE_PLATFORM_BASE_NAME "win")
    set(ZENGINE_PLATFORM_WINDOWS_DESKTOP TRUE)
    set(ZENGINE_PLATFORM_WINDOWS TRUE)
elseif(ANDROID)
    set(ZENGINE_PLATFORM_BASE_NAME "android")
    set(ZENGINE_PLATFORM_ANDROID TRUE)
elseif(${CMAKE_SYSTEM_NAME} MATCHES "Linux")
    set(ZENGINE_PLATFORM_BASE_NAME "linux")
    set(ZENGINE_PLATFORM_LINUX TRUE)
elseif(IOS)
    set(ZENGINE_PLATFORM_BASE_NAME "ios")
    set(ZENGINE_PLATFORM_IOS TRUE)
elseif(${CMAKE_SYSTEM_NAME} MATCHES "Darwin")
    if(IOS)
        set(ZENGINE_PLATFORM_BASE_NAME "ios")
        set(ZENGINE_PLATFORM_IOS TRUE)
    else()
        set(ZENGINE_PLATFORM_BASE_NAME "darwin")
        set(ZENGINE_PLATFORM_DARWIN TRUE)
    endif()
endif()

if(NOT ZENGINE_ARCH_NAME)
    if((CMAKE_SYSTEM_PROCESSOR MATCHES "AMD64") OR (CMAKE_SYSTEM_PROCESSOR MATCHES "x86_64"))
        set(ZENGINE_ARCH_NAME "x64")
    else()
        set(ZENGINE_ARCH_NAME "x86")
    endif()
endif()
if(NOT ZENGINE_PLATFORM_BASE_NAME)
    message(FATAL_ERROR "Unsupported platform: ${CMAKE_SYSTEM_NAME}")
endif()
set(ZENGINE_PLATFORM_NAME "${ZENGINE_PLATFORM_BASE_NAME}_${ZENGINE_ARCH_NAME}")

if(ZENGINE_PLATFORM_ANDROID OR ZENGINE_PLATFORM_IOS)
	set(ZENGINE_PREFERRED_LIB_TYPE "STATIC")
else()
	set(ZENGINE_PREFERRED_LIB_TYPE "SHARED")
endif()

if (ZENGINE_PLATFORM_WINDOWS_DESKTOP OR ZENGINE_PLATFORM_LINUX OR ZENGINE_PLATFORM_DARWIN)
	SET(ZENGINE_IS_DEV_PLATFORM TRUE)
ELSE()
	SET(ZENGINE_IS_DEV_PLATFORM FALSE)
ENDIF()
